# ═══════════════════════════════════════════════════════════════
#  CONFIGURATION — Solana Wallet Tracker (Webhook Version)
# ═══════════════════════════════════════════════════════════════

# ── Helius API ────────────────────────────────────────────────────
HELIUS_API_KEY=helius_sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Obtenez votre clé sur : https://dev.helius.xyz/dashboard

# ── Webhook Security ──────────────────────────────────────────────
WEBHOOK_SECRET=0123456789abcdef0123456789abcdef
# Secret 32-char hex (générez : python -c "import secrets; print(secrets.token_hex(16))")

# ── Server ───────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/wallet_tracker.db
# Pour PostgreSQL en prod : postgresql+asyncpg://user:pass@host/db

# ── Monitoring ──────────────────────────────────────────────────
LOG_LEVEL=INFO
# Niveaux : DEBUG, INFO, WARNING, ERROR

# ── Defaults ─────────────────────────────────────────────────────
DEFAULT_MIN_AMOUNT=0.1
# Montant minimum (SOL) pour déclencher une alerte

# ═══════════════════════════════════════════════════════════════
#  TERMUX-SPECIFIC (optionnel)
#  Laissez vide si non-TerMux
# ═══════════════════════════════════════════════════════════════
TERMUX_SESSION_NAME=wallet_tracker
# Nom de la session tmux (si utilisé)
